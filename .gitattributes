# Normalize line endings: store all text files with LF in the repo,
# let Git handle checkout conversion per-platform.
* text=auto eol=lf

# Explicitly mark common text types (in case auto-detection misfires)
*.rs    text eol=lf
*.toml  text eol=lf
*.lock  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf

# Binary files: never touch
*.png   binary
*.jpg   binary
*.ico   binary
